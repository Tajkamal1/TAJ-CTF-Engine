{
  "name": "TAJ-CTF-Engine",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "TAJ-CTF-Engine",
      "onAutoForward": "openBrowser"
    }
  },

  "postCreateCommand": "pip install -r requirements.txt",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.flake8"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
